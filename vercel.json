{
  "headers": [
    {
      "source": "/:path*.(png|jpg|jpeg|webp|avif|gif|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    },
    {
      "source": "/:path*.(webm)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "video/webm"
        }
      ]
    }
  ]
}
